<!DOCTYPE html>
<html lang="<%= lang || 'pt' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Sistema Bancário</title>
  <link rel="stylesheet" href="/banking/css/main.css" />
</head>
<body>
  <%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="page-header">
      <h1>⚙️ <%= translations.settings %></h1>
    </div>

    <%- include('../partials/flash') %>
    <%- include('../partials/errors') %>

    <div class="card" style="max-width: 600px;">
      <div class="card-header"><h2><%= translations.systemPreferences %></h2></div>
      <form method="POST" action="/configuracoes" class="form">
        <div class="card-body">
          <div class="form-group">
            <label for="language" class="form-label"><%= translations.language %></label>
            <select id="language" name="language" class="form-control">
              <option value="pt" <%= settings.language === 'pt' ? 'selected' : '' %>>🇧🇷 <%= translations.portuguese %></option>
              <option value="en" <%= settings.language === 'en' ? 'selected' : '' %>>🇺🇸 <%= translations.english %></option>
            </select>
          </div>

          <div class="form-group">
            <label for="currencyFormat" class="form-label"><%= translations.currencyFormat %></label>
            <select id="currencyFormat" name="currencyFormat" class="form-control">
              <option value="BRL" <%= settings.currencyFormat === 'BRL' ? 'selected' : '' %>>🇧🇷 BRL - Real Brasileiro (R$)</option>
              <option value="USD" <%= settings.currencyFormat === 'USD' ? 'selected' : '' %>>🇺🇸 USD - US Dollar ($)</option>
              <option value="EUR" <%= settings.currencyFormat === 'EUR' ? 'selected' : '' %>>🇪🇺 EUR - Euro (€)</option>
            </select>
          </div>

          <div class="form-group">
            <label for="dateFormat" class="form-label"><%= translations.dateFormat %></label>
            <select id="dateFormat" name="dateFormat" class="form-control">
              <option value="DD/MM/YYYY" <%= settings.dateFormat === 'DD/MM/YYYY' ? 'selected' : '' %>>DD/MM/AAAA (Padrão Brasileiro)</option>
              <option value="MM/DD/YYYY" <%= settings.dateFormat === 'MM/DD/YYYY' ? 'selected' : '' %>>MM/DD/YYYY (Padrão Americano)</option>
              <option value="YYYY-MM-DD" <%= settings.dateFormat === 'YYYY-MM-DD' ? 'selected' : '' %>>AAAA-MM-DD (ISO 8601)</option>
            </select>
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary"><%= translations.save %></button>
        </div>
      </form>
    </div>

    <div class="card mt-4" style="max-width: 600px;">
      <div class="card-header"><h2>ℹ️ <%= translations.systemInfo %></h2></div>
      <div class="card-body">
        <div class="detail-grid">
          <div class="detail-item">
            <span class="detail-label"><%= translations.withdrawalLimit %> - <%= translations.individualClient %></span>
            <span class="detail-value badge badge-info">R$ 1.000,00</span>
          </div>
          <div class="detail-item">
            <span class="detail-label"><%= translations.withdrawalLimit %> - <%= translations.businessClient %></span>
            <span class="detail-value badge badge-info">R$ 5.000,00</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Versão</span>
            <span class="detail-value">1.0.0</span>
          </div>
        </div>
      </div>
    </div>
  </main>
  <footer class="footer"><p>Sistema Bancário &copy; <%= new Date().getFullYear() %></p></footer>
  <script src="/banking/js/main.js"></script>
</body>
</html>
