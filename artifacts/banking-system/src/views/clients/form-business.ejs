<!DOCTYPE html>
<html lang="<%= lang || 'pt' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Sistema Bancário</title>
  <link rel="stylesheet" href="/banking/css/main.css" />
</head>
<body>
  <%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="page-header">
      <h1><%= client ? '✏️ ' + translations.edit : '➕ ' + translations.newClient %> <%= translations.businessClient %></h1>
      <a href="/clientes/pj" class="btn btn-outline"><%= translations.cancel %></a>
    </div>

    <%- include('../partials/errors') %>

    <div class="card">
      <form method="POST" action="<%= client ? '/clientes/pj/' + client.id + '/editar' : '/clientes/pj' %>" class="form">
        <div class="form-grid">
          <div class="form-group full-width">
            <label for="companyName" class="form-label required"><%= translations.companyName %></label>
            <input type="text" id="companyName" name="companyName" value="<%= client ? client.companyName : '' %>" class="form-control" required />
          </div>
          <div class="form-group">
            <label for="tradeName" class="form-label required"><%= translations.tradeName %></label>
            <input type="text" id="tradeName" name="tradeName" value="<%= client ? client.tradeName : '' %>" class="form-control" required />
          </div>
          <div class="form-group">
            <label for="cnpj" class="form-label required"><%= translations.cnpj %></label>
            <input type="text" id="cnpj" name="cnpj" value="<%= client ? client.cnpj : '' %>" class="form-control" placeholder="00.000.000/0001-00" required />
          </div>
          <div class="form-group">
            <label for="phone" class="form-label"><%= translations.phone %></label>
            <input type="text" id="phone" name="phone" value="<%= client ? client.phone : '' %>" class="form-control" placeholder="(11) 3333-3333" />
          </div>
          <div class="form-group">
            <label for="email" class="form-label"><%= translations.email %></label>
            <input type="email" id="email" name="email" value="<%= client ? client.email : '' %>" class="form-control" />
          </div>
          <div class="form-group">
            <label for="category" class="form-label"><%= translations.category %></label>
            <select id="category" name="category" class="form-control">
              <option value="standard" <%= (!client || client.category === 'standard') ? 'selected' : '' %>><%= translations.standard %></option>
              <option value="premium" <%= (client && client.category === 'premium') ? 'selected' : '' %>><%= translations.premium %></option>
              <option value="corporate" <%= (client && client.category === 'corporate') ? 'selected' : '' %>><%= translations.corporate %></option>
            </select>
          </div>
          <div class="form-group">
            <label for="balance" class="form-label"><%= translations.balance %></label>
            <input type="number" id="balance" name="balance" value="<%= client ? client.balance : '0' %>" step="0.01" min="0" class="form-control" />
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary"><%= translations.save %></button>
          <a href="/clientes/pj" class="btn btn-outline"><%= translations.cancel %></a>
        </div>
      </form>
    </div>
  </main>
  <footer class="footer"><p>Sistema Bancário &copy; <%= new Date().getFullYear() %></p></footer>
  <script src="/banking/js/main.js"></script>
</body>
</html>
