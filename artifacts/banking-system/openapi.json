  "components": {
    "parameters": {
      "clientId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "ID numérico do cliente",
        "schema": { "type": "integer", "example": 1 }
      }
    },
    "schemas": {
      "IndividualClient": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "fullName": { "type": "string", "example": "Ana Paula Silva" },
          "monthlyIncome": { "type": "number", "format": "float", "example": 5000 },
          "age": { "type": "integer", "example": 32 },
          "phone": { "type": "string", "example": "11999991111" },
          "email": { "type": "string", "format": "email", "example": "ana.paula@email.com" },
          "category": {
            "type": "string",
            "enum": ["standard", "premium", "vip"],
            "example": "premium"
          },
          "balance": { "type": "number", "format": "float", "example": 14500 },
          "createdAt": { "type": "string", "example": "2026-04-06 00:53:56" },
          "updatedAt": { "type": "string", "example": "2026-04-06 00:55:11" }
        }
      },
      "CreateIndividualClientRequest": {
        "type": "object",
        "required": ["fullName", "age", "monthlyIncome"],
        "properties": {
          "fullName": {
            "type": "string",
            "minLength": 2,
            "example": "João da Silva",
            "description": "Nome completo (mínimo 2 caracteres)"
          },
          "age": {
            "type": "integer",
            "minimum": 1,
            "maximum": 120,
            "example": 35,
            "description": "Idade em anos"
          },
          "monthlyIncome": {
            "type": "number",
            "minimum": 0,
            "example": 8000,
            "description": "Renda mensal em reais"
          },
          "phone": {
            "type": "string",
            "example": "11988887777",
            "description": "Telefone (opcional)"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "joao@email.com",
            "description": "E-mail válido (opcional)"
          },
          "category": {
            "type": "string",
            "enum": ["standard", "premium", "vip"],
            "default": "standard",
            "example": "premium"
          },
          "balance": {
            "type": "number",
            "minimum": 0,
            "default": 0,
            "example": 5000,
            "description": "Saldo inicial da conta"
          }
        }
      },
      "UpdateIndividualClientRequest": {
        "type": "object",
        "properties": {
          "fullName": { "type": "string", "minLength": 2, "example": "João da Silva" },
          "age": { "type": "integer", "minimum": 1, "maximum": 120, "example": 36 },
          "monthlyIncome": { "type": "number", "minimum": 0, "example": 9000 },
          "phone": { "type": "string", "example": "11911112222" },
          "email": { "type": "string", "format": "email", "example": "joao.novo@email.com" },
          "category": { "type": "string", "enum": ["standard", "premium", "vip"], "example": "vip" },
          "balance": { "type": "number", "minimum": 0, "example": 6000 }
        }
      },
      "IndividualClientPage": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/IndividualClient" }
          },
          "total": { "type": "integer", "example": 35 },
          "page": { "type": "integer", "example": 1 },
          "limit": { "type": "integer", "example": 10 },
          "totalPages": { "type": "integer", "example": 4 }
        }
      },
      "BusinessClient": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "companyName": { "type": "string", "example": "Tech Solutions Ltda" },
          "tradeName": { "type": "string", "example": "TechSol" },
          "cnpj": { "type": "string", "example": "11.222.333/0001-44" },
          "phone": { "type": "string", "example": "1133334444" },
          "email": { "type": "string", "format": "email", "example": "contato@techsol.com.br" },
          "category": {
            "type": "string",
            "enum": ["standard", "corporate", "enterprise"],
            "example": "corporate"
          },
          "balance": { "type": "number", "format": "float", "example": 150000 },
          "createdAt": { "type": "string", "example": "2026-04-06 00:53:56" },
          "updatedAt": { "type": "string", "example": "2026-04-06 00:53:56" }
        }
      },
      "CreateBusinessClientRequest": {
        "type": "object",
        "required": ["companyName", "tradeName", "cnpj"],
        "properties": {
          "companyName": {
            "type": "string",
            "minLength": 2,
            "example": "Inovação Digital Ltda",
            "description": "Razão social (mínimo 2 caracteres)"
          },
          "tradeName": {
            "type": "string",
            "minLength": 1,
            "example": "InovaDigital",
            "description": "Nome fantasia"
          },
          "cnpj": {
            "type": "string",
            "minLength": 14,
            "maxLength": 18,
            "example": "22.333.444/0001-55",
            "description": "CNPJ com ou sem formatação (único no sistema)"
          },
          "phone": { "type": "string", "example": "1144445555" },
          "email": { "type": "string", "format": "email", "example": "contato@inovadigital.com.br" },
          "category": {
            "type": "string",
            "enum": ["standard", "corporate", "enterprise"],
            "default": "standard",
            "example": "enterprise"
          },
          "balance": {
            "type": "number",
            "minimum": 0,
            "default": 0,
            "example": 100000,
            "description": "Saldo inicial da conta"
          }
        }
      },
      "UpdateBusinessClientRequest": {
        "type": "object",
        "properties": {
          "companyName": { "type": "string", "minLength": 2 },
          "tradeName": { "type": "string", "minLength": 1 },
          "cnpj": { "type": "string", "minLength": 14, "maxLength": 18 },
          "phone": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "category": { "type": "string", "enum": ["standard", "corporate", "enterprise"] },
          "balance": { "type": "number", "minimum": 0 }
        }
      },
      "BusinessClientPage": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BusinessClient" }
          },
          "total": { "type": "integer", "example": 9 },
          "page": { "type": "integer", "example": 1 },
          "limit": { "type": "integer", "example": 10 },
          "totalPages": { "type": "integer", "example": 1 }
        }
      },
      "WithdrawRequest": {
        "type": "object",
        "required": ["amount"],
        "properties": {
          "amount": {
            "type": "number",
            "minimum": 0.01,
            "example": 500,
            "description": "Valor a sacar. PF: máximo R$ 1.000,00. PJ: máximo R$ 5.000,00."
          },
          "description": {
            "type": "string",
            "default": "Saque",
            "example": "Saque em dinheiro",
            "description": "Descrição opcional da operação"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 42 },
          "clientId": { "type": "integer", "example": 1 },
          "clientType": {
            "type": "string",
            "enum": ["individual", "business"],
            "example": "individual"
          },
          "transactionType": {
            "type": "string",
            "enum": ["withdrawal", "deposit"],
            "example": "withdrawal"
          },
          "amount": { "type": "number", "example": 500 },
          "description": { "type": "string", "example": "Saque em dinheiro" },
          "previousBalance": { "type": "number", "example": 14500 },
          "newBalance": { "type": "number", "example": 14000 },
          "createdAt": { "type": "string", "example": "2026-04-06 12:30:00" }
        }
      },
      "WithdrawResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "transaction": { "$ref": "#/components/schemas/Transaction" },
          "newBalance": { "type": "number", "example": 14000 }
        }
      },
      "StatementPage": {
        "type": "object",
        "properties": {
          "transactions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Transaction" }
          },
          "currentBalance": { "type": "number", "example": 14500 },
          "total": { "type": "integer", "example": 7 },
          "page": { "type": "integer", "example": 1 },
          "limit": { "type": "integer", "example": 10 },
          "totalPages": { "type": "integer", "example": 1 }
        }
      },
      "Settings": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "language": {
            "type": "string",
            "enum": ["pt", "en"],
            "example": "pt",
            "description": "Idioma da interface"
          },
          "currencyFormat": {
            "type": "string",
            "enum": ["BRL", "USD", "EUR"],
            "example": "BRL",
            "description": "Formato de moeda"
          },
          "dateFormat": {
            "type": "string",
            "enum": ["DD/MM/YYYY", "MM/DD/YYYY", "YYYY-MM-DD"],
            "example": "DD/MM/YYYY",
            "description": "Formato de data"
          },
          "active": { "type": "boolean", "example": true },
          "createdAt": { "type": "string", "example": "2026-04-06 00:53:11" },
          "updatedAt": { "type": "string", "example": "2026-04-06 01:55:14" }
        }
      },
      "UpdateSettingsRequest": {
        "type": "object",
        "properties": {
          "language": {
            "type": "string",
            "enum": ["pt", "en"],
            "example": "pt",
            "description": "Idioma da interface"
          },
          "currencyFormat": {
            "type": "string",
            "enum": ["BRL", "USD", "EUR"],
            "example": "BRL",
            "description": "Formato de moeda"
          },
          "dateFormat": {
            "type": "string",
            "enum": ["DD/MM/YYYY", "MM/DD/YYYY", "YYYY-MM-DD"],
            "example": "DD/MM/YYYY",
            "description": "Formato de data"
          }
        }
      },
      "SuccessMessage": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string", "example": "Operação realizada com sucesso" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "Mensagem de erro" }
        }
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "Validation Error" },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": { "type": "string", "example": "fullName" },
                "message": { "type": "string", "example": "Nome completo é obrigatório" }
              }
            }
          }
        }
      },
      "NotFoundError": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "Cliente não encontrado" },
          "statusCode": { "type": "integer", "example": 404 }
        }
      }
    },
    "responses": {
      "NotFound": {
        "description": "Recurso não encontrado",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/NotFoundError" },
            "example": {
              "error": "Cliente não encontrado",
              "statusCode": 404
            }
          }
        }
      },
      "ValidationError": {
        "description": "Erro de validação nos dados enviados",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ValidationError" },
            "example": {
              "error": "Validation Error",
              "errors": [
                { "field": "fullName", "message": "Nome completo é obrigatório" }
              ]
            }
          }
        }
      }
    }
  }
}
